{
  "version": "1.2.2",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-env --allow-run --allow-ffi --allow-net main.ts",
    "compile:macos": "deno compile --target aarch64-apple-darwin --allow-read --allow-write --allow-env --allow-run --allow-ffi --allow-net --self-extracting --include ../domain/src/specs/generated/dwcSchema.json --output ./dist/darwinkit_aarch64-apple-darwin main.ts",
    "compile:linux": "deno compile --target x86_64-unknown-linux-gnu --allow-read --allow-write --allow-env --allow-run --allow-ffi --allow-net --self-extracting --include ../domain/src/specs/generated/dwcSchema.json --output ./dist/darwinkit_x86_64-unknown-linux-gnu main.ts",
    "test": "deno test --allow-write --allow-env --allow-read --allow-run --allow-ffi --allow-net --fail-fast --reporter=dot"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0-rc.7",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0-rc.7",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0-rc.7",
    "@cliffy/testing": "jsr:@cliffy/testing@1.0.0-rc.7",
    "@dwkt/domain/types": "../domain/src/types/mod.ts",
    "@dwkt/domain/schemas": "../domain/src/schemas/mod.ts",
    "@dwkt/domain/errors": "../domain/src/errors/mod.ts",
    "@dwkt/domain/specs": "../domain/src/specs/mod.ts",
    "@dwkt/core/workspace": "../core/src/workspace/mod.ts",
    "@dwkt/core/validation": "../core/src/validation/mod.ts",
    "@dwkt/core/loading": "../core/src/loading/mod.ts",
    "@dwkt/core/errors": "../core/src/errors/mod.ts",
    "@dwkt/core/transform": "../core/src/transform/mod.ts",
    "@dwkt/core/import": "../core/src/import/mod.ts",
    "@std/cli": "jsr:@std/cli@^1.0.7",
    "@std/fmt": "jsr:@std/fmt@^1.0.8",
    "@std/path": "jsr:@std/path@^1.0.8"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": true
  },
  "compilerOptions": {
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictPropertyInitialization": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false
  }
}
