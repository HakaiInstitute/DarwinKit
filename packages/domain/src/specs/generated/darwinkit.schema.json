{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "anyOf": [
        {
          "type": "string",
          "description": "Unique workspace identifier (auto-generated UUID if omitted)."
        },
        {
          "type": "null"
        }
      ]
    },
    "name": {
      "anyOf": [
        {
          "type": "string",
          "description": "Workspace name. Default: 'Workspace'.",
          "default": "Workspace"
        },
        {
          "type": "null"
        }
      ]
    },
    "version": {
      "anyOf": [
        {
          "type": "string",
          "description": "Configuration version. Default: '1.0.0'.",
          "default": "1.0.0"
        },
        {
          "type": "null"
        }
      ]
    },
    "description": {
      "anyOf": [
        {
          "type": "string",
          "description": "Human-readable workspace description."
        },
        {
          "type": "null"
        }
      ]
    },
    "standard": {
      "anyOf": [
        {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "object",
              "properties": {
                "base": {
                  "type": "string"
                },
                "variant": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "required": [
                "base"
              ],
              "additionalProperties": false
            }
          ],
          "description": "Target biodiversity standard. Accepts a string (e.g. 'obis') or object { base, variant }. Known variants ('obis', 'gbif') are normalized to { base: 'darwin-core', variant: <name> }. Default: { base: 'darwin-core', variant: 'obis' }."
        },
        {
          "type": "null"
        }
      ]
    },
    "datasetRules": {
      "anyOf": [
        {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "ruleType": {
                    "type": "string",
                    "enum": [
                      "foreignKey"
                    ],
                    "description": "Type of cross-dataset rule."
                  },
                  "sourceDataset": {
                    "type": "string",
                    "description": "Name of the source dataset."
                  },
                  "sourceField": {
                    "type": "string",
                    "description": "Field name in the source dataset."
                  },
                  "targetDataset": {
                    "type": "string",
                    "description": "Name of the target dataset."
                  },
                  "targetField": {
                    "type": "string",
                    "description": "Field name in the target dataset."
                  },
                  "requirement": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "required",
                          "recommended",
                          "optional"
                        ]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "description": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "ruleType",
                  "sourceDataset",
                  "sourceField",
                  "targetDataset",
                  "targetField"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "ruleType": {
                    "type": "string",
                    "enum": [
                      "dependency"
                    ],
                    "description": "Type of intra-dataset dependency rule."
                  },
                  "sourceDataset": {
                    "anyOf": [
                      {
                        "type": "string",
                        "description": "Name of the dataset this rule applies to."
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "when": {
                    "anyOf": [
                      {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "object",
                            "properties": {
                              "field": {
                                "type": "string"
                              },
                              "equals": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "field",
                              "equals"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "field": {
                                "type": "string"
                              },
                              "in": {
                                "type": "array",
                                "prefixItems": [
                                  {
                                    "type": "string"
                                  }
                                ],
                                "minItems": 1,
                                "items": {
                                  "type": "string"
                                }
                              }
                            },
                            "required": [
                              "field",
                              "in"
                            ],
                            "additionalProperties": false
                          }
                        ],
                        "description": "Condition that triggers this rule. Omit for unconditional rules."
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "require": {
                    "anyOf": [
                      {
                        "type": "array",
                        "prefixItems": [
                          {
                            "type": "string"
                          }
                        ],
                        "minItems": 1,
                        "items": {
                          "type": "string"
                        }
                      },
                      {
                        "type": "object",
                        "properties": {
                          "oneOf": {
                            "type": "array",
                            "prefixItems": [
                              {
                                "type": "string"
                              }
                            ],
                            "minItems": 1,
                            "items": {
                              "type": "string"
                            }
                          }
                        },
                        "required": [
                          "oneOf"
                        ],
                        "additionalProperties": false
                      }
                    ],
                    "description": "Fields that must be present. Array means all required; { oneOf: [...] } means at least one."
                  },
                  "level": {
                    "anyOf": [
                      {
                        "type": "string",
                        "enum": [
                          "required",
                          "recommended",
                          "optional"
                        ]
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "message": {
                    "anyOf": [
                      {
                        "type": "string",
                        "description": "Custom error message."
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "ruleType",
                  "require"
                ],
                "additionalProperties": false
              }
            ],
            "title": "Dataset Rule",
            "description": "Defines a cross-dataset foreign key or intra-dataset dependency rule."
          },
          "description": "Foreign key and dependency rules across or within datasets."
        },
        {
          "type": "null"
        }
      ]
    },
    "validation": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "nullValues": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Values to treat as null during validation.",
                  "default": [
                    "NA",
                    "N/A",
                    "",
                    "NULL",
                    "null"
                  ]
                },
                {
                  "type": "null"
                }
              ]
            },
            "failFast": {
              "anyOf": [
                {
                  "type": "boolean",
                  "description": "Stop validation on first error. Default: false."
                },
                {
                  "type": "null"
                }
              ]
            },
            "debug": {
              "anyOf": [
                {
                  "type": "boolean",
                  "description": "Enable debug output. Default: false."
                },
                {
                  "type": "null"
                }
              ]
            },
            "outputDir": {
              "anyOf": [
                {
                  "type": "string",
                  "description": "Directory for validation output files. Default: './output'."
                },
                {
                  "type": "null"
                }
              ]
            },
            "description": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ]
            },
            "maxViolationsPerField": {
              "anyOf": [
                {
                  "type": "integer",
                  "allOf": [
                    {
                      "description": "Maximum number of violations to report per field."
                    }
                  ]
                },
                {
                  "type": "null"
                }
              ]
            },
            "enableSuggestions": {
              "anyOf": [
                {
                  "type": "boolean",
                  "description": "Enable suggestion messages for violations. Default: true."
                },
                {
                  "type": "null"
                }
              ]
            },
            "datasets": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string",
                        "description": "Unique name for this dataset."
                      },
                      "class": {
                        "type": "string",
                        "description": "Darwin Core class: Event, Occurrence, Taxon, ExtendedMeasurementOrFact, dnaDerivedData, ResourceRelationship."
                      },
                      "path": {
                        "type": "string",
                        "description": "File path to the CSV data file."
                      },
                      "description": {
                        "anyOf": [
                          {
                            "type": "string"
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "fieldMappings": {
                        "anyOf": [
                          {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "originName": {
                                  "type": "string",
                                  "description": "Source column name in the CSV file."
                                },
                                "targetName": {
                                  "type": "string",
                                  "description": "Target Darwin Core field name."
                                },
                                "requirement": {
                                  "anyOf": [
                                    {
                                      "type": "string",
                                      "enum": [
                                        "required",
                                        "recommended",
                                        "optional"
                                      ]
                                    },
                                    {
                                      "type": "null"
                                    }
                                  ]
                                },
                                "constraints": {
                                  "anyOf": [
                                    {
                                      "type": "array",
                                      "items": {
                                        "anyOf": [
                                          {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "enum": [
                                                  "range"
                                                ]
                                              },
                                              "min": {
                                                "anyOf": [
                                                  {
                                                    "anyOf": [
                                                      {
                                                        "type": "number"
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "NaN"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "Infinity"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "-Infinity"
                                                        ]
                                                      }
                                                    ]
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "max": {
                                                "anyOf": [
                                                  {
                                                    "anyOf": [
                                                      {
                                                        "type": "number"
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "NaN"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "Infinity"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "-Infinity"
                                                        ]
                                                      }
                                                    ]
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "inclusive": {
                                                "anyOf": [
                                                  {
                                                    "type": "boolean"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "message": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type"
                                            ],
                                            "additionalProperties": false
                                          },
                                          {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "enum": [
                                                  "required"
                                                ]
                                              },
                                              "level": {
                                                "anyOf": [
                                                  {
                                                    "type": "string",
                                                    "enum": [
                                                      "required",
                                                      "recommended",
                                                      "optional"
                                                    ]
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "allowEmpty": {
                                                "anyOf": [
                                                  {
                                                    "type": "boolean"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "allowWhitespace": {
                                                "anyOf": [
                                                  {
                                                    "type": "boolean"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "message": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type"
                                            ],
                                            "additionalProperties": false
                                          },
                                          {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "enum": [
                                                  "unique"
                                                ]
                                              },
                                              "message": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type"
                                            ],
                                            "additionalProperties": false
                                          },
                                          {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "enum": [
                                                  "pattern"
                                                ]
                                              },
                                              "pattern": {
                                                "type": "string"
                                              },
                                              "flags": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "message": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type",
                                              "pattern"
                                            ],
                                            "additionalProperties": false
                                          },
                                          {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "enum": [
                                                  "length"
                                                ]
                                              },
                                              "minLength": {
                                                "anyOf": [
                                                  {
                                                    "anyOf": [
                                                      {
                                                        "type": "number"
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "NaN"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "Infinity"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "-Infinity"
                                                        ]
                                                      }
                                                    ]
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "maxLength": {
                                                "anyOf": [
                                                  {
                                                    "anyOf": [
                                                      {
                                                        "type": "number"
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "NaN"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "Infinity"
                                                        ]
                                                      },
                                                      {
                                                        "type": "string",
                                                        "enum": [
                                                          "-Infinity"
                                                        ]
                                                      }
                                                    ]
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              },
                                              "message": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type"
                                            ],
                                            "additionalProperties": false
                                          },
                                          {
                                            "type": "object",
                                            "properties": {
                                              "type": {
                                                "type": "string",
                                                "enum": [
                                                  "format"
                                                ]
                                              },
                                              "format": {
                                                "type": "string",
                                                "enum": [
                                                  "email",
                                                  "url",
                                                  "uuid",
                                                  "iso8601",
                                                  "decimal-degrees",
                                                  "integer"
                                                ]
                                              },
                                              "message": {
                                                "anyOf": [
                                                  {
                                                    "type": "string"
                                                  },
                                                  {
                                                    "type": "null"
                                                  }
                                                ]
                                              }
                                            },
                                            "required": [
                                              "type",
                                              "format"
                                            ],
                                            "additionalProperties": false
                                          }
                                        ]
                                      }
                                    },
                                    {
                                      "type": "null"
                                    }
                                  ]
                                },
                                "preset": {
                                  "anyOf": [
                                    {
                                      "type": "string"
                                    },
                                    {
                                      "type": "null"
                                    }
                                  ]
                                }
                              },
                              "required": [
                                "originName",
                                "targetName"
                              ],
                              "additionalProperties": false
                            },
                            "description": "Mappings from CSV columns to Darwin Core fields."
                          },
                          {
                            "type": "null"
                          }
                        ]
                      }
                    },
                    "required": [
                      "name",
                      "class",
                      "path"
                    ],
                    "additionalProperties": false,
                    "title": "Dataset Configuration",
                    "description": "Configuration for a single dataset to validate against a Darwin Core specification."
                  },
                  "description": "Datasets to validate."
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false,
          "title": "Validation Settings",
          "description": "Configuration for the validation workflow."
        },
        {
          "type": "null"
        }
      ]
    },
    "transform": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "nullValues": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "Values to treat as null during transformation.",
                  "default": [
                    "NA",
                    "N/A",
                    "",
                    "NULL",
                    "null"
                  ]
                },
                {
                  "type": "null"
                }
              ]
            },
            "inputs": {
              "type": "object",
              "description": "Input data source configuration."
            },
            "postImportTransforms": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  },
                  "description": "SQL transforms to run after data import."
                },
                {
                  "type": "null"
                }
              ]
            },
            "datasets": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Unique name for this transform dataset."
                  },
                  "class": {
                    "type": "string",
                    "description": "Darwin Core class for the transform output."
                  },
                  "source": {
                    "anyOf": [
                      {
                        "type": "object",
                        "additionalProperties": {
                          "type": "string"
                        },
                        "description": "Named SQL sources: alias → table name or SQL query."
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "description": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "fields": {
                    "anyOf": [
                      {
                        "type": "object",
                        "additionalProperties": {
                          "anyOf": [
                            {
                              "type": "string"
                            },
                            {
                              "anyOf": [
                                {
                                  "type": "number"
                                },
                                {
                                  "type": "string",
                                  "enum": [
                                    "NaN"
                                  ]
                                },
                                {
                                  "type": "string",
                                  "enum": [
                                    "Infinity"
                                  ]
                                },
                                {
                                  "type": "string",
                                  "enum": [
                                    "-Infinity"
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "null"
                            }
                          ]
                        },
                        "description": "Field mappings: Darwin Core field name → SQL expression, number, or null."
                      },
                      {
                        "type": "null"
                      }
                    ]
                  }
                },
                "required": [
                  "name",
                  "class"
                ],
                "additionalProperties": false,
                "title": "Transform Dataset Configuration",
                "description": "Configuration for a dataset in a transform workflow."
              },
              "description": "Datasets to transform."
            },
            "output": {
              "type": "object",
              "properties": {
                "outputDir": {
                  "type": "string",
                  "description": "Directory for transform output files."
                },
                "outputFilesWithTimestamp": {
                  "anyOf": [
                    {
                      "type": "boolean",
                      "description": "Append timestamp to output file names."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "exportDB": {
                  "type": "boolean",
                  "description": "Whether to export the DuckDB database file."
                },
                "exportDBFileName": {
                  "anyOf": [
                    {
                      "type": "string",
                      "description": "File name for the exported database."
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "dropNullColumns": {
                  "anyOf": [
                    {
                      "type": "boolean",
                      "description": "Drop columns that contain only null values."
                    },
                    {
                      "type": "null"
                    }
                  ]
                }
              },
              "required": [
                "outputDir",
                "exportDB"
              ],
              "additionalProperties": false,
              "title": "Transform Output",
              "description": "Output configuration for the transform workflow."
            }
          },
          "required": [
            "inputs",
            "datasets",
            "output"
          ],
          "additionalProperties": false,
          "title": "Transform Settings",
          "description": "Configuration for the data transformation workflow."
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "additionalProperties": false,
  "title": "DarwinKit Workspace Configuration",
  "description": "Top-level configuration for a DarwinKit workspace. Must include at least one of 'validation' or 'transform'.",
  "anyOf": [
    {
      "required": [
        "validation"
      ]
    },
    {
      "required": [
        "transform"
      ]
    }
  ]
}
