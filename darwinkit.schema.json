{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique workspace identifier (auto-generated UUID if omitted)."
    },
    "name": {
      "type": "string",
      "description": "Workspace name. Default: 'Workspace'.",
      "default": "Workspace"
    },
    "version": {
      "type": "string",
      "description": "Configuration version. Default: '1.0.0'.",
      "default": "1.0.0"
    },
    "description": {
      "type": "string",
      "description": "Human-readable workspace description."
    },
    "standard": {
      "type": "string",
      "enum": [
        "obis",
        "gbif"
      ],
      "description": "Target biodiversity standard. Determines which obligation metadata drives requirement levels. Default: 'obis'."
    },
    "crossDatasetRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ruleType",
          "sourceDataset",
          "sourceField",
          "targetDataset",
          "targetField"
        ],
        "properties": {
          "ruleType": {
            "type": "string",
            "enum": [
              "foreignKey"
            ],
            "description": "Type of cross-dataset rule."
          },
          "sourceDataset": {
            "type": "string",
            "description": "Name of the source dataset."
          },
          "sourceField": {
            "type": "string",
            "description": "Field name in the source dataset."
          },
          "targetDataset": {
            "type": "string",
            "description": "Name of the target dataset."
          },
          "targetField": {
            "type": "string",
            "description": "Field name in the target dataset."
          },
          "requirement": {
            "type": "string",
            "enum": [
              "required",
              "recommended",
              "optional"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "description": "Defines a referential integrity rule between two datasets.",
        "title": "Cross-Dataset Rule"
      },
      "description": "Rules enforcing referential integrity between datasets."
    },
    "validation": {
      "type": "object",
      "required": [],
      "properties": {
        "nullValues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Values to treat as null during validation.",
          "default": [
            "NA",
            "N/A",
            "",
            "NULL",
            "null"
          ]
        },
        "failFast": {
          "type": "boolean",
          "description": "Stop validation on first error. Default: false."
        },
        "debug": {
          "type": "boolean",
          "description": "Enable debug output. Default: false."
        },
        "outputDir": {
          "type": "string",
          "description": "Directory for validation output files. Default: './output'."
        },
        "description": {
          "type": "string"
        },
        "maxViolationsPerField": {
          "type": "integer",
          "description": "Maximum number of violations to report per field.",
          "title": "int"
        },
        "enableSuggestions": {
          "type": "boolean",
          "description": "Enable suggestion messages for violations. Default: true."
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "class",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique name for this dataset."
              },
              "class": {
                "type": "string",
                "enum": ["Event", "Occurrence", "Taxon", "ExtendedMeasurementOrFact", "DnaDerivedData", "ResourceRelationship"],
                "description": "Darwin Core class: Event, Occurrence, Taxon, ExtendedMeasurementOrFact, DnaDerivedData, ResourceRelationship."
              },
              "path": {
                "type": "string",
                "description": "File path to the CSV data file."
              },
              "description": {
                "type": "string"
              },
              "fieldMappings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "originName",
                    "targetName"
                  ],
                  "properties": {
                    "originName": {
                      "type": "string"
                    },
                    "targetName": {
                      "type": "string"
                    },
                    "requirement": {
                      "type": "string",
                      "enum": [
                        "required",
                        "recommended",
                        "optional"
                      ]
                    },
                    "constraints": {
                      "type": "array",
                      "items": {
                        "anyOf": [
                          {
                            "type": "object",
                            "required": [
                              "type"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "range"
                                ]
                              },
                              "min": {
                                "type": "number"
                              },
                              "max": {
                                "type": "number"
                              },
                              "inclusive": {
                                "type": "boolean"
                              },
                              "message": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "required": [
                              "type",
                              "requirement"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "required"
                                ]
                              },
                              "allowEmpty": {
                                "type": "boolean"
                              },
                              "allowWhitespace": {
                                "type": "boolean"
                              },
                              "requirement": {
                                "type": "string",
                                "enum": [
                                  "required",
                                  "recommended",
                                  "optional"
                                ]
                              },
                              "message": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "required": [
                              "type"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "unique"
                                ]
                              },
                              "message": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "required": [
                              "type",
                              "pattern"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "pattern"
                                ]
                              },
                              "pattern": {
                                "type": "string"
                              },
                              "flags": {
                                "type": "string"
                              },
                              "message": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "required": [
                              "type"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "length"
                                ]
                              },
                              "minLength": {
                                "type": "number"
                              },
                              "maxLength": {
                                "type": "number"
                              },
                              "message": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "required": [
                              "type",
                              "format"
                            ],
                            "properties": {
                              "type": {
                                "type": "string",
                                "enum": [
                                  "format"
                                ]
                              },
                              "format": {
                                "type": "string",
                                "enum": [
                                  "email",
                                  "url",
                                  "uuid",
                                  "iso8601",
                                  "decimal-degrees",
                                  "integer"
                                ]
                              },
                              "message": {
                                "type": "string"
                              }
                            },
                            "additionalProperties": false
                          }
                        ]
                      }
                    },
                    "preset": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                },
                "description": "Mappings from CSV columns to Darwin Core fields."
              }
            },
            "additionalProperties": false,
            "description": "Configuration for a single dataset to validate against a Darwin Core specification.",
            "title": "Dataset Configuration"
          },
          "description": "Datasets to validate."
        }
      },
      "additionalProperties": false,
      "description": "Configuration for the validation workflow.",
      "title": "Validation Settings"
    },
    "transform": {
      "type": "object",
      "required": [
        "inputs",
        "datasets",
        "output"
      ],
      "properties": {
        "nullValues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Values to treat as null during transformation.",
          "default": [
            "NA",
            "N/A",
            "",
            "NULL",
            "null"
          ]
        },
        "inputs": {
          "$id": "/schemas/object",
          "anyOf": [
            {
              "type": "object"
            },
            {
              "type": "array"
            }
          ],
          "description": "Input data source configuration.",
          "title": "object"
        },
        "postImportTransforms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "SQL transforms to run after data import."
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "class"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique name for this transform dataset."
              },
              "class": {
                "type": "string",
                "description": "Darwin Core class for the transform output."
              },
              "source": {
                "$id": "/schemas/object",
                "anyOf": [
                  {
                    "type": "object"
                  },
                  {
                    "type": "array"
                  }
                ],
                "description": "an object in the TypeScript meaning, i.e. the `object` type",
                "title": "object"
              },
              "description": {
                "type": "string"
              },
              "fields": {
                "$id": "/schemas/object",
                "anyOf": [
                  {
                    "type": "object"
                  },
                  {
                    "type": "array"
                  }
                ],
                "description": "an object in the TypeScript meaning, i.e. the `object` type",
                "title": "object"
              }
            },
            "additionalProperties": false,
            "description": "Configuration for a dataset in a transform workflow.",
            "title": "Transform Dataset Configuration"
          },
          "description": "Datasets to transform."
        },
        "output": {
          "type": "object",
          "required": [
            "outputDir",
            "exportDB"
          ],
          "properties": {
            "outputDir": {
              "type": "string",
              "description": "Directory for transform output files."
            },
            "outputFilesWithTimestamp": {
              "type": "boolean",
              "description": "Append timestamp to output file names."
            },
            "exportDB": {
              "type": "boolean",
              "description": "Whether to export the DuckDB database file."
            },
            "exportDBFileName": {
              "type": "string",
              "description": "File name for the exported database."
            },
            "dropNullColumns": {
              "type": "boolean",
              "description": "Drop columns that contain only null values."
            }
          },
          "additionalProperties": false,
          "description": "Output configuration for the transform workflow.",
          "title": "Transform Output"
        }
      },
      "additionalProperties": false,
      "description": "Configuration for the data transformation workflow.",
      "title": "Transform Settings"
    }
  },
  "additionalProperties": false,
  "description": "Top-level configuration for a DarwinKit workspace. Must include at least one of 'validation' or 'transform'.",
  "title": "DarwinKit Workspace Configuration",
  "anyOf": [
    {
      "required": [
        "validation"
      ]
    },
    {
      "required": [
        "transform"
      ]
    }
  ]
}
