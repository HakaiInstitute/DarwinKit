{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique workspace identifier (auto-generated UUID if omitted)."
    },
    "name": {
      "type": "string",
      "description": "Workspace name. Default: 'Workspace'.",
      "default": "Workspace"
    },
    "version": {
      "type": "string",
      "description": "Configuration version. Default: '1.0.0'.",
      "default": "1.0.0"
    },
    "description": {
      "type": "string",
      "description": "Human-readable workspace description."
    },
    "crossDatasetRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "ruleType",
          "sourceDataset",
          "sourceField",
          "targetDataset",
          "targetField"
        ],
        "properties": {
          "ruleType": {
            "type": "string",
            "enum": [
              "foreignKey",
              "referentialIntegrity"
            ],
            "description": "Type of cross-dataset rule: foreignKey or referentialIntegrity."
          },
          "sourceDataset": {
            "type": "string",
            "description": "Name of the source dataset."
          },
          "sourceField": {
            "type": "string",
            "description": "Field name in the source dataset."
          },
          "targetDataset": {
            "type": "string",
            "description": "Name of the target dataset."
          },
          "targetField": {
            "type": "string",
            "description": "Field name in the target dataset."
          },
          "enforcement": {
            "type": "string",
            "enum": [
              "required",
              "recommended",
              "optional"
            ],
            "description": "How strictly a validator is enforced: required (error), recommended (warning), or optional (info).",
            "title": "Enforcement Level"
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false,
        "description": "Defines a referential integrity rule between two datasets.",
        "title": "Cross-Dataset Rule"
      },
      "description": "Rules enforcing referential integrity between datasets."
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "validation": {
      "type": "object",
      "required": [],
      "properties": {
        "nullValues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Values to treat as null during validation.",
          "default": [
            "NA",
            "N/A",
            "",
            "NULL",
            "null"
          ]
        },
        "failFast": {
          "type": "boolean",
          "description": "Stop validation on first error. Default: false."
        },
        "debug": {
          "type": "boolean",
          "description": "Enable debug output. Default: false."
        },
        "outputDir": {
          "type": "string",
          "description": "Directory for validation output files. Default: './output'."
        },
        "description": {
          "type": "string"
        },
        "maxViolationsPerField": {
          "type": "number",
          "description": "Maximum number of violations to report per field."
        },
        "enableSuggestions": {
          "type": "boolean",
          "description": "Enable suggestion messages for violations. Default: true."
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "spec",
              "path"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique name for this dataset."
              },
              "spec": {
                "type": "string",
                "description": "Darwin Core specification identifier, e.g. 'dwc-event', 'dwc-occurrence', 'obis-event'."
              },
              "path": {
                "type": "string",
                "description": "File path to the CSV data file."
              },
              "description": {
                "type": "string"
              },
              "profile": {
                "type": "string",
                "description": "Validation profile to apply to this dataset."
              },
              "fieldMappings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "originName",
                    "targetName"
                  ],
                  "properties": {
                    "originName": {
                      "type": "string",
                      "description": "Source column name in the CSV file."
                    },
                    "targetName": {
                      "type": "string",
                      "description": "Target Darwin Core field name."
                    },
                    "isRequired": {
                      "type": "boolean",
                      "description": "Whether this field mapping is required."
                    },
                    "requirement": {
                      "type": "string",
                      "description": "Requirement level for this field."
                    },
                    "constraints": {
                      "type": "object",
                      "required": [],
                      "properties": {},
                      "additionalProperties": {
                        "$id": "/schemas/unknown",
                        "title": "unknown"
                      }
                    },
                    "validators": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "required": [
                          "type",
                          "enforcement"
                        ],
                        "properties": {
                          "type": {
                            "type": "string",
                            "enum": [
                              "required",
                              "unique",
                              "pattern",
                              "range",
                              "length",
                              "format"
                            ],
                            "description": "Type of validation to apply: required, unique, pattern, range, length, or format.",
                            "title": "Validator Type"
                          },
                          "enforcement": {
                            "type": "string",
                            "enum": [
                              "required",
                              "recommended",
                              "optional"
                            ],
                            "description": "How strictly a validator is enforced: required (error), recommended (warning), or optional (info).",
                            "title": "Enforcement Level"
                          },
                          "params": {
                            "type": "object",
                            "required": [],
                            "properties": {
                              "min": {
                                "type": "number",
                                "description": "Minimum value for range validation."
                              },
                              "max": {
                                "type": "number",
                                "description": "Maximum value for range validation."
                              },
                              "inclusive": {
                                "type": "boolean",
                                "description": "Whether range bounds are inclusive."
                              },
                              "minLength": {
                                "type": "number",
                                "description": "Minimum string length."
                              },
                              "maxLength": {
                                "type": "number",
                                "description": "Maximum string length."
                              },
                              "pattern": {
                                "type": "string",
                                "description": "Regular expression pattern to match."
                              },
                              "flags": {
                                "type": "string",
                                "description": "Regular expression flags."
                              },
                              "format": {
                                "type": "string",
                                "enum": [
                                  "email",
                                  "url",
                                  "uuid",
                                  "iso8601",
                                  "decimal-degrees",
                                  "integer"
                                ],
                                "description": "Expected value format."
                              },
                              "allowEmpty": {
                                "type": "boolean",
                                "description": "Allow empty string values."
                              },
                              "allowWhitespace": {
                                "type": "boolean",
                                "description": "Allow whitespace-only values."
                              },
                              "custom": {
                                "type": "object",
                                "required": [],
                                "properties": {},
                                "additionalProperties": {
                                  "$id": "/schemas/unknown",
                                  "title": "unknown"
                                }
                              }
                            },
                            "additionalProperties": false,
                            "description": "Parameters for the validator, varying by validator type.",
                            "title": "Validator Parameters"
                          },
                          "message": {
                            "type": "string",
                            "description": "Custom error message for validation failures."
                          }
                        },
                        "additionalProperties": false,
                        "description": "Configuration for a field validator with type, enforcement level, and optional parameters.",
                        "title": "Validator Configuration"
                      }
                    }
                  },
                  "additionalProperties": false,
                  "description": "Maps a source CSV column to a Darwin Core target field.",
                  "title": "Field Mapping"
                },
                "description": "Mappings from CSV columns to Darwin Core fields."
              }
            },
            "additionalProperties": false,
            "description": "Configuration for a single dataset to validate against a Darwin Core specification.",
            "title": "Dataset Configuration"
          },
          "description": "Datasets to validate."
        }
      },
      "additionalProperties": false,
      "description": "Configuration for the validation workflow.",
      "title": "Validation Settings"
    },
    "transform": {
      "type": "object",
      "required": [
        "inputs",
        "datasets",
        "output"
      ],
      "properties": {
        "nullValues": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Values to treat as null during transformation.",
          "default": [
            "NA",
            "N/A",
            "",
            "NULL",
            "null"
          ]
        },
        "inputs": {
          "$id": "/schemas/object",
          "anyOf": [
            {
              "type": "object"
            },
            {
              "type": "array"
            }
          ],
          "description": "Input data source configuration.",
          "title": "object"
        },
        "postImportTransforms": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "SQL transforms to run after data import."
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "name",
              "profile"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Unique name for this transform dataset."
              },
              "profile": {
                "type": "string",
                "description": "Darwin Core profile for the transform output."
              },
              "source": {
                "$id": "/schemas/object",
                "anyOf": [
                  {
                    "type": "object"
                  },
                  {
                    "type": "array"
                  }
                ],
                "description": "an object in the TypeScript meaning, i.e. the `object` type",
                "title": "object"
              },
              "description": {
                "type": "string"
              },
              "fields": {
                "$id": "/schemas/object",
                "anyOf": [
                  {
                    "type": "object"
                  },
                  {
                    "type": "array"
                  }
                ],
                "description": "an object in the TypeScript meaning, i.e. the `object` type",
                "title": "object"
              }
            },
            "additionalProperties": false,
            "description": "Configuration for a dataset in a transform workflow.",
            "title": "Transform Dataset Configuration"
          },
          "description": "Datasets to transform."
        },
        "output": {
          "type": "object",
          "required": [
            "outputDir",
            "exportDB"
          ],
          "properties": {
            "outputDir": {
              "type": "string",
              "description": "Directory for transform output files."
            },
            "outputFilesWithTimestamp": {
              "type": "boolean",
              "description": "Append timestamp to output file names."
            },
            "exportDB": {
              "type": "boolean",
              "description": "Whether to export the DuckDB database file."
            },
            "exportDBFileName": {
              "type": "string",
              "description": "File name for the exported database."
            },
            "dropNullColumns": {
              "type": "boolean",
              "description": "Drop columns that contain only null values."
            }
          },
          "additionalProperties": false,
          "description": "Output configuration for the transform workflow.",
          "title": "Transform Output"
        }
      },
      "additionalProperties": false,
      "description": "Configuration for the data transformation workflow.",
      "title": "Transform Settings"
    }
  },
  "additionalProperties": false,
  "description": "Top-level configuration for a DarwinKit workspace. Must include at least one of 'validation' or 'transform'.",
  "title": "DarwinKit Workspace Configuration",
  "anyOf": [
    {
      "required": [
        "validation"
      ]
    },
    {
      "required": [
        "transform"
      ]
    }
  ]
}
