{
  "workspace": [
    "./packages/domain",
    "./packages/core",
    "./packages/cli"
  ],
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "imports": {
    "@dwkt/domain": "./packages/domain/mod.ts",
    "@dwkt/core": "./packages/core/mod.ts",
    "@dwkt/api": "./packages/api/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/csv": "jsr:@std/csv@^1.0.6",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@duckdb/node-api": "npm:@duckdb/node-api@^1.3.2-alpha.26",
    "effect": "npm:effect@^3.19.15"
  },
  "tasks": {
    "dev:cli": "cd packages/cli && deno task dev",
    "test": "deno test --allow-all --parallel",
    "test:domain": "deno test packages/domain/",
    "test:core": "deno test packages/core/",
    "test:cli": "deno test packages/cli/",
    "test:integration": "deno test packages/cli/src/integration.test.ts --allow-all"
  },
  "exclude": [
    "build",
    "coverage",
    ".context"
  ],
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "packages/",
      "test/"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-slow-types"
      ]
    },
    "include": [
      "packages/",
      "test/"
    ]
  }
}
