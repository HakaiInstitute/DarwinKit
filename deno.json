{
  "workspace": [
    "./packages/domain",
    "./packages/core",
    "./packages/cli"
  ],
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "deno.ns"
    ]
  },
  "imports": {
    "@dwkt/domain": "./packages/domain/mod.ts",
    "@dwkt/core": "./packages/core/mod.ts",
    "@dwkt/api": "./packages/api/mod.ts",
    "@duckdb/node-api": "npm:@duckdb/node-api@^1.3.2-alpha.26",
    "@std/csv": "jsr:@std/csv@^1.0.6",
    "@std/testing": "jsr:@std/testing@^1.0.16",
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.5",
    "effect": "npm:effect@^3.19.15",
    "txml": "npm:txml@^5.2.1",
    "@types/node": "npm:@types/node@^22.10.9"
  },
  "tasks": {
    "test": {
      "dependencies": [
        "test:domain",
        "test:core",
        "test:integration",
        "test:cli"
      ]
    },
    "test:domain": "deno test packages/domain/ --parallel --reporter=dot",
    "test:core": "deno test packages/core/ --allow-read --allow-write --allow-ffi --allow-env=READABLE_STREAM --parallel --reporter=dot",
    "test:integration": "deno test test/ --allow-read --allow-write --allow-ffi --allow-env=READABLE_STREAM --parallel --reporter=dot",
    "test:cli": "deno test packages/cli/ --allow-run --parallel --reporter=dot",
    "compile:macos": "deno compile --target aarch64-apple-darwin --allow-read --allow-write --allow-env=READABLE_STREAM --output ./dist/darwinkit_darwin ./packages/cli/src/main.ts",
    "compile:linux": "deno compile --target x86_64-unknown-linux-gnu --allow-read --allow-write --allow-env=READABLE_STREAM --output ./dist/darwinkit_linux ./packages/cli/src/main.ts"
  },
  "exclude": [
    "dist",
    "coverage"
  ],
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "src/",
      "test/",
      "demo/"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "jsx-no-children-prop",
        "no-slow-types"
      ]
    },
    "include": [
      "src/",
      "test/",
      "demo/"
    ]
  }
}
