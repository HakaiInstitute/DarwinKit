{
  "workspace": [
    "./packages/domain",
    "./packages/core",
    "./packages/cli"
  ],
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "imports": {
    "@dwkt/domain/types": "./packages/domain/src/types/mod.ts",
    "@dwkt/domain/schemas": "./packages/domain/src/schemas/mod.ts",
    "@dwkt/domain/errors": "./packages/domain/src/errors/mod.ts",
    "@dwkt/domain/specs": "./packages/domain/src/specs/mod.ts",
    "@dwkt/core/workspace": "./packages/core/src/workspace/mod.ts",
    "@dwkt/core/validation": "./packages/core/src/validation/mod.ts",
    "@dwkt/core/loading": "./packages/core/src/loading/mod.ts",
    "@dwkt/core/errors": "./packages/core/src/errors/mod.ts",
    "@dwkt/core/transform": "./packages/core/src/transform/mod.ts",
    "@dwkt/core/import": "./packages/core/src/import/mod.ts",
    "@std/assert": "jsr:@std/assert@^1.0.6",
    "@std/csv": "jsr:@std/csv@^1.0.6",
    "@std/path": "jsr:@std/path@^1.0.8",
    "@std/yaml": "jsr:@std/yaml@^1.0.11",
    "@duckdb/node-api": "npm:@duckdb/node-api@^1.3.2-alpha.26",
    "effect": "npm:effect@^3.19.15"
  },
  "tasks": {
    "cli": "deno task --cwd packages/cli dev",
    "test": {
      "dependencies": [
        "test:domain",
        "test:core",
        "test:cli",
        "test:integration"
      ]
    },
    "test:domain": "deno task --cwd packages/domain test",
    "test:core": "deno task --cwd packages/core test",
    "test:cli": "deno task --cwd packages/cli test",
    "test:integration": "deno test test --allow-read --allow-write --allow-ffi --allow-env=READABLE_STREAM"
  },
  "exclude": [
    "build",
    "coverage",
    ".context"
  ],
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "include": [
      "packages/",
      "test/"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "no-slow-types"
      ]
    },
    "include": [
      "packages/",
      "test/"
    ]
  }
}
